# VisionOps Local - Kubernetes Secrets (Minikube)
#
# USAGE:
#   cp k8s/secrets-local.yaml.example k8s/secrets-local.yaml
#   kubectl apply -f k8s/secrets-local.yaml
#
# NOTE: secrets-local.yaml is gitignored.
# For local dev, simple passwords are fine — not internet-facing.
---
apiVersion: v1
kind: Secret
metadata:
  name: vision-redis-credentials
  namespace: vision-infra
type: Opaque
stringData:
  password: "redis-local-password"

---
apiVersion: v1
kind: Secret
metadata:
  name: vision-minio-credentials
  namespace: vision-infra
type: Opaque
stringData:
  rootUser: "minioadmin"
  rootPassword: "minioadmin"

---
apiVersion: v1
kind: Secret
metadata:
  name: vision-grafana-credentials
  namespace: vision-monitoring
type: Opaque
stringData:
  admin-user: "admin"
  admin-password: "admin"

# Duplicated into vision-app so pods can reference them via secretKeyRef
---
apiVersion: v1
kind: Secret
metadata:
  name: vision-redis-credentials
  namespace: vision-app
type: Opaque
stringData:
  password: "redis-local-password"

---
apiVersion: v1
kind: Secret
metadata:
  name: vision-minio-credentials
  namespace: vision-app
type: Opaque
stringData:
  rootUser: "minioadmin"
  rootPassword: "minioadmin"
