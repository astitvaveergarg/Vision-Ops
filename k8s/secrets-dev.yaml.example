# VisionOps Dev - Kubernetes Secrets
#
# USAGE:
#   cp k8s/secrets-dev.yaml.example k8s/secrets-dev.yaml
#   # Fill in credentials, then:
#   kubectl apply -f k8s/secrets-dev.yaml
#
# NOTE: secrets-dev.yaml is gitignored — never commit real credentials.
---
apiVersion: v1
kind: Secret
metadata:
  name: vision-redis-credentials
  namespace: vision-infra
type: Opaque
stringData:
  password: "<CHANGE_ME>"           # e.g. openssl rand -base64 24

---
apiVersion: v1
kind: Secret
metadata:
  name: vision-minio-credentials
  namespace: vision-infra
type: Opaque
stringData:
  rootUser: "<CHANGE_ME>"           # MinIO access key (username)
  rootPassword: "<CHANGE_ME>"       # MinIO secret key (min 8 chars)

---
apiVersion: v1
kind: Secret
metadata:
  name: vision-grafana-credentials
  namespace: vision-monitoring
type: Opaque
stringData:
  admin-user: "admin"
  admin-password: "<CHANGE_ME>"     # openssl rand -base64 24

# Duplicated into vision-app so pods can reference them via secretKeyRef
---
apiVersion: v1
kind: Secret
metadata:
  name: vision-redis-credentials
  namespace: vision-app
type: Opaque
stringData:
  password: "<CHANGE_ME>"

---
apiVersion: v1
kind: Secret
metadata:
  name: vision-minio-credentials
  namespace: vision-app
type: Opaque
stringData:
  rootUser: "<CHANGE_ME>"
  rootPassword: "<CHANGE_ME>"
