# VisionOps Production - Kubernetes Secrets
#
# USAGE:
#   cp k8s/secrets-prod.yaml.example k8s/secrets-prod.yaml
#   # Generate strong credentials:
#   #   openssl rand -base64 32   <- for passwords
#   #   openssl rand -hex 20      <- for access keys
#   kubectl apply -f k8s/secrets-prod.yaml
#
# NOTE: secrets-prod.yaml is gitignored — NEVER commit production credentials.
# Use a secrets manager (GCP Secret Manager, AWS SSM, Vault) for production.
---
apiVersion: v1
kind: Secret
metadata:
  name: vision-redis-credentials
  namespace: vision-infra
type: Opaque
stringData:
  password: "<CHANGE_ME>"           # openssl rand -base64 32

---
apiVersion: v1
kind: Secret
metadata:
  name: vision-minio-credentials
  namespace: vision-infra
type: Opaque
stringData:
  rootUser: "<CHANGE_ME>"           # openssl rand -hex 20
  rootPassword: "<CHANGE_ME>"       # openssl rand -base64 32

---
apiVersion: v1
kind: Secret
metadata:
  name: vision-grafana-credentials
  namespace: vision-monitoring
type: Opaque
stringData:
  admin-user: "admin"
  admin-password: "<CHANGE_ME>"     # openssl rand -base64 24

# Duplicated into vision-app so pods can reference them via secretKeyRef
---
apiVersion: v1
kind: Secret
metadata:
  name: vision-redis-credentials
  namespace: vision-app
type: Opaque
stringData:
  password: "<CHANGE_ME>"           # openssl rand -base64 32

---
apiVersion: v1
kind: Secret
metadata:
  name: vision-minio-credentials
  namespace: vision-app
type: Opaque
stringData:
  rootUser: "<CHANGE_ME>"           # openssl rand -hex 20
  rootPassword: "<CHANGE_ME>"       # openssl rand -base64 32
