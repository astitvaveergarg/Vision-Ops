# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Redis (Minikube NodePort for local development)
REDIS_HOST=localhost
REDIS_PORT=30379

# MinIO (Minikube NodePort for local development)
MINIO_ENDPOINT=localhost:30900
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=vision-images
MINIO_SECURE=false

# PostgreSQL (optional)
POSTGRES_HOST=localhost
POSTGRES_PORT=30432
POSTGRES_DB=visiondb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# YOLO Model
MODEL_PATH=models/yolov8n.pt
CONF_THRESHOLD=0.25
IOU_THRESHOLD=0.45
